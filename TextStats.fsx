let text =
    """
    Peut-on être progressiste et manger de la viande ?
    On jase d'oppressions liées, d'empathie qui fane quand il fait chaud et on finit ça avec deux recettes de salades.
    Elise Desaulniers
    juil. 06, 2025

    La question revient par vagues. La dernière a été déclenchée par ma journaliste préférée, Vanessa Destiné, qui signait la semaine dernière dans Urbania une chronique brillante, nourrie de son vécu et de l’essai à paraître de Suzanne Zaccour, Pourquoi Trump ne mange pas de tofu. Une phrase, surtout, claque comme un verdict :

        « La façon dont on exploite les animaux, c’est aussi la façon dont on exploite les femmes. »

    Fait surprenant : le texte a surtout récolté des partages enthousiastes, peu d’émojis-steak ni d’injonctions « laissez-nous vivre ». Visiblement, beaucoup sentaient confusément le lien sans toujours avoir les mots pour le dire. Je profite donc de cette brèche ouverte pour creuser les fondations.
    Zaccour : le patriarcat jusque dans l’assiette

    J’ai pu lire l’essai de Suzanne Zaccour en avant-première. Juriste, docteure d’Oxford et autrice de La fabrique du viol, elle montre que l’exploitation animale n’est pas un simple « sujet à part » : elle s’inscrit pleinement dans la logique patriarcale, et contribue à la renforcer.

        « Nous aimons les animaux comme les hommes disent aimer les femmes, écrit-elle, réconciliant tant bien que mal cet amour avec la violence qu’on tolère à leur égard. Nous aimons Bambi… et nous agissons en chasseur. »

    Elle ne se contente pas de juxtaposer sexisme et spécisme. Elle expose leurs justifications communes : l’appel à la nature, à la tradition, à la nécessité ; l’invisibilisation de la souffrance ; l’érotisation ou l’infantilisation des victimes. Chaque oppression légitime l’autre.

    Oppressions liées, résistances solidaires

    Longtemps, j’ai résumé le spécisme comme « du sexisme ou du racisme appliqué aux animaux ». C’était un raccourci. Ces oppressions ne sont pas des parallèles : elles se co-produisent.
    Naturalisation des hiérarchies, animalisation ou déshumanisation, évocation de traditions, refus de voir la douleur : tant que ces ressorts fonctionnent quelque part, ils alimentent l’injustice partout.

    Virilité anxieuse et assiettes réactionnaires

    Ces dynamiques ne sont pas théoriques : elles s’incarnent dans nos gestes les plus banals. La viande est devenue l’un des terrains privilégiés de la résistance aux idéaux égalitaires et au progressisme. Comme je l’écris dans la préface québécoise à La politique sexuelle de la viande de Carol J. Adams, la Carnivore Diet s’affiche aujourd’hui comme un symbole de virilité défensive face aux féministes, aux écolos et aux végés.

    De Joe Rogan à Jordan Peterson, en passant par Shawn Baker, toute une galaxie masculiniste érige le steak en étendard d’un prétendu « ordre naturel » fondé sur la force et la domination. Même Mike Tyson, ex-végane, se filme chassant l’élan pour « redevenir fort ». Carol J. Adams le résume mieux que n’importe qui :

        « Partout où il y a de la virilité (anxieuse), on retrouve de la consommation de viande. »

    La publicité n’est pas en reste : en France, une campagne radio soupirait qu’« on ne peut plus tenir la porte aux dames sans passer pour un dragueur… heureusement qu’il nous reste le confit de canard ». L’assiette devient un refuge identitaire. Manger de la viande, ce n’est plus seulement nourrir son corps : c’est réaffirmer sa place dans un monde hiérarchique, nostalgique, viril.

    Racisme et animalisation : la frontière politique de l’humain

    Nos choix alimentaires ne sont jamais neutres : ils peuvent consolider ou fissurer les hiérarchies. Le lien entre spécisme et racisme passe par un procédé bien connu : l’animalisation.

    La militante antiraciste (et précieuse amie) Dalila Awada rappelle que comparer certains groupes humains à des singes, rats ou insectes a longtemps servi à justifier l’esclavage, la colonisation, les génocides – et continue d’alimenter des politiques migratoires meurtrières.

    Deux exemples récents :
    • 9 octobre 2023 – L’ex-ministre israélien Yoav Gallant, au sujet du siège de Gaza : « Nous combattons des animaux humains. »
    • Printemps 2024 – Donald Trump, en meeting en parlant des immigrants : « Non, ils ne sont pas humains, ce sont des animaux. »

    Les philosophes Aph et Syl Ko, dans Aphro-ism, écrivent que « le racisme repose sur la notion d’animalité ». Tant que l’on continue à justifier l’exploitation des animaux par leur prétendue infériorité naturelle, on maintient intacte la structure idéologique qui rend pensable – et acceptable – l’exclusion de certains humains jugés « moins humains ».

    La frontière entre humain et animal est, depuis toujours, une frontière politique. Être reconnu·e comme pleinement humain·e – rationnel·le, moral·e, civilisé·e – a longtemps été un privilège réservé aux hommes blancs, européens, propriétaires. En dehors de cette norme, femmes, personnes racisées, esclavisées, handicapées, enfants, ont été associées à l’animalité pour mieux justifier leur mise sous tutelle.

    Quand le spécisme alimente le racisme

    Si l’on traite certains humains comme des animaux, c’est peut-être parce qu’on traite d’abord les animaux comme inférieurs. C’est l’hypothèse que testent les psychologues Kimberly Costello et Gordon Hodson, dans un article dont la traduction vient de paraître dans L’Amorce.

    À travers une série d’études frappantes, ils montrent que plus une personne adhère à l’idée de la supériorité humaine, plus elle tend à déshumaniser certains groupes humains — immigré·e·s, Noir·e·s, musulman·e·s — en les percevant comme « moins évolués », « moins sensibles », « moins moraux ». Cette déshumanisation justifie alors les préjugés, la discrimination, le refus d’aide.
    Caricature parue dans le Daily Mail le 17 novembre 2015...

    Iels appellent cela le modèle interespèces des préjugés. Nos rapports aux animaux sont le terreau de nos rapports aux humains. Et cela commence tôt : les enfants qui perçoivent une grande séparation entre humains et animaux manifestent aussi plus de racisme. Inversement, souligner les ressemblances entre espèces – même dans une simple vidéo éducative – peut faire chuter les préjugés. Ce n’est pas en descendant l’humain de son piédestal qu’on l’humilie — c’est en reconstruisant un monde plus juste, à hauteur de toutes les espèces.

    Capacitisme : même hiérarchie des aptitudes

    Un dernier point de convergence : le capacitisme, cette logique qui valorise les vies selon leur degré d’autonomie, de productivité, d’efficacité cognitive. La seconde édition papier de L’Amorce — enfin disponible au Québec — consacre un dossier complet à ce croisement trop souvent oublié.

    Même logique, même dommage : la grille qui juge les personnes handicapées comme « moins aptes » relègue aussi les animaux hors du cercle moral. La théoricienne Sunaura Taylor, dans Braves Bêtes, pousse la réflexion : tant que la vulnérabilité et la dépendance sont vues comme des défauts à corriger, on perpétue à la fois le capacitisme et le spécisme.

    Les deux s’appuient sur une hiérarchie des capacités. Or, tant que l’on doit prouver son intelligence ou son utilité pour mériter le respect, certains humains – et tous les animaux – resteront au bas de l’échelle.

    Pour conclure

    Sexisme, racisme, capacitisme, spécisme : quatre piliers d’un même édifice. Celui d’un monde qui naturalise la domination, classe les êtres selon leur conformité à une norme arbitraire, et invisibilise les souffrances qu’il cause. Tant qu’une oppression reste pensable, elle continue de légitimer les autres.

    Défaire ces hiérarchies, ce n’est pas une coquetterie morale : c’est une condition de la justice.

    Alors, est-ce qu’on peut être progressiste et manger de la viande ? Bien sur, comme on peut être antiraciste et trouver que les frontières, parfois, c’est bien utile. Mais à un moment, il faut bien voir que ce qu’on met dans nos assiettes peut nourrir les mêmes logiques qu’on prétend combattre.
    """

let ngrams n (w: string) =
    [|
        if w.Length >= n then
            let ngramsCount = w.Length - n
            yield!
                [| 0..ngramsCount |]
                |> Seq.map (fun i -> w.Substring(i, n))
    |]

type WordStats = {
    Word: string
    Count: int
    Chars: string[]
    Bigrams: string[]
    Trigrams: string[]
}
module WordStats =
    let regexNumeric = System.Text.RegularExpressions.Regex @"\d+"

    let isWordValid word =
        let punctuations =
            [|
                ":"; "-"; "–"; "—"
                ";" ; "•"; "?"; "!"
            |]

        System.String.IsNullOrWhiteSpace word |> not &&
        punctuations |> Array.contains word |> not &&
        regexNumeric.IsMatch word |> not

    let trimWord (word: string) =
        [| "("; ")"; "« "; " »"; "…" |]
        |> Array.fold (fun (acc: string) (c: string) -> acc.Replace(c, "")) word
        |> _.Trim()
        

    let parse (text: string) =
        text.Split [| '\n'; ' ' |]
        |> Array.map _.ToLowerInvariant()
        |> Array.map trimWord
        |> Array.filter isWordValid
        |> Array.groupBy id
        |> Array.map (fun (word, occurrences) ->
            {
                Word = word
                Count = occurrences.Length
                Chars = word |> ngrams 1
                Bigrams = word |> ngrams 2
                Trigrams = word |> ngrams 3
            }
        )
        |> Array.sortByDescending _.Count


type Percent = Percent of decimal
module Percent =
    let from (n: int) (total: int) =
        System.Math.Round(decimal n / decimal total, 6)
        |> Percent

    let toString (Percent p) =
        let p100 = p * 100m
        p100.ToString "0.0000" + "%"


type Frequency = Frequency of string * Percent
module Frequency =
    let toString (Frequency (s, percent)) =
        let strPercent = percent |> Percent.toString
        $"{s}: {strPercent}"

    let ngrams getNgrams stats =
        let allNgrams =
            stats
            |> Array.collect (fun s ->
                getNgrams s
                |> Array.groupBy id
                |> Array.map (fun (ngram, counts) -> ngram, counts.Length * s.Count)
            )
            |> Array.groupBy fst
            |> Array.map (fun (ngram, counts) ->
                let totalNgramsCount = counts |> Array.sumBy snd
                ngram, totalNgramsCount
            )
        
        let totalNgrams =
            allNgrams
            |> Array.sumBy snd

        allNgrams
        |> Array.map (fun (ngram, count) ->
            let frequency = Percent.from count totalNgrams
            ngram, frequency
        )
        |> Array.sortByDescending snd
        |> Array.map Frequency


type GlobalFrequencies = {
    Chars: Frequency[]
    Bigrams: Frequency[]
    Trigrams: Frequency[]
    Words: Frequency[]
}
module GlobalFrequencies =
    let analyze (stats: WordStats[]) =
        let totalWords =
            stats
            |> Array.sumBy (fun s -> s.Count)
        
        let wordFrequencies =
            stats
            |> Array.map (fun s ->
                let frequency = Percent.from s.Count totalWords
                Frequency (s.Word, frequency)
            )

        {
            Chars = stats |> Frequency.ngrams _.Chars
            Bigrams = stats |> Frequency.ngrams _.Bigrams
            Trigrams = stats |> Frequency.ngrams _.Trigrams
            Words = wordFrequencies
        }


text
|> WordStats.parse
|> GlobalFrequencies.analyze
|> fun s -> {|
    Chars = s.Chars |> Array.map Frequency.toString
    Bigrams = s.Bigrams |> Array.map Frequency.toString
    Trigrams = s.Trigrams |> Array.map Frequency.toString
    Words = s.Words |> Array.map Frequency.toString
|}